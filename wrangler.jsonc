{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-04-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],

  // ============================================================
  // D1 Database binding (ACTIVE — local-first via wrangler)
  // ============================================================
  // مفعَّل افتراضيًا عبر binding "DB". في التطوير المحلي يُنشئ
  // wrangler ملف SQLite تحت .wrangler/state/v3/d1 ويستخدمه
  // كل من `wrangler pages dev` و `wrangler d1 execute` ما دامت
  // نفس الـ database_name مستعملة (لذا لا تستخدم --d1=DB=...
  // الذي يُنتج hash مختلفًا ويُسبِّب تعارض الملفات).
  //
  // للإنتاج: استبدل database_id بقيمة حقيقية من
  //   npx wrangler d1 create tafseer-production
  // ثم طبّق الترحيلات: npm run db:migrate:prod
  //
  // المراجع:
  //   - docs/d1-setup.md — خطوات الإعداد الكاملة + تنبيهات الأمان
  //   - docs/database.md — مخطّط البيانات والجداول
  //
  // عند تفعيل القسم، يستعمل التطبيق تلقائيًا D1 provider بدلًا من
  // seed provider، مع fallback آمن إلى seed عند فشل أي استعلام.
  // ============================================================
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tafseer-production",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "db/migrations"
    }
  ]
}
